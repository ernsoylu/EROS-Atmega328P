# =====================================================================
# GENERATED by tools/erosgen.py from app.yaml - DO NOT EDIT
#
# Application 'knobdemo' on the EROS kernel. Only the peripherals
# selected in the YAML are compiled; everything else costs 0 bytes.
# =====================================================================

MCU     := atmega328p
F_CPU   := 16000000UL
TARGET  := knobdemo

VPATH   := ../../../kernel ../../../drivers

APP_SRCS := main.c knob.c knob_Intfc.c knob_Param.c Rte.c
SRCS     := $(APP_SRCS) adc.c eros.c config.c
OBJS     := $(SRCS:.c=.o)
DEPS     := $(SRCS:.c=.d)

CC      := avr-gcc
OBJCOPY := avr-objcopy
SIZE    := avr-size
AVRDUDE := avrdude

PORT    ?= /dev/ttyUSB0
BAUD    ?= 57600          # old-bootloader Nano; Optiboot: 115200

CFLAGS  := -Wall -Wextra -Werror -std=c99 -Os -flto \
           -ffunction-sections -fdata-sections -fno-common \
           -mmcu=$(MCU) -DF_CPU=$(F_CPU) \
           -I. -I../../../kernel -I../../../drivers
LDFLAGS := -Wl,--gc-sections -Wl,-Map=$(TARGET).map

.PHONY: all size flash clean config

all: $(TARGET).hex size

$(TARGET).elf: $(OBJS)
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $^

$(TARGET).hex: $(TARGET).elf
	$(OBJCOPY) -O ihex -R .eeprom $< $@

%.o: %.c
	$(CC) $(CFLAGS) -MMD -MP -c -o $@ $<

size: $(TARGET).elf
	@echo "---- final image (LTO) --------------------------------------"
	@$(SIZE) -B $(TARGET).elf

flash: $(TARGET).hex
	$(AVRDUDE) -v -p m328p -c arduino -P $(PORT) -b $(BAUD) \
	           -U flash:w:$(TARGET).hex:i

# Regenerate config.h/config.c/Makefile/os_gen.h from the YAML.
# Run this after editing app.yaml (config is NOT auto-rebuilt,
# so a Python-less CI can still 'make' from committed output).
config:
	python3 ../../erosgen.py app.yaml

clean:
	rm -f $(OBJS) $(DEPS) $(TARGET).elf $(TARGET).hex $(TARGET).map

-include $(DEPS)
